{
	"name": "scan-overrides",
	"version": "0.1.0",
	"description": "CLI tool that scans package.json overrides and determines whether CVE-related overrides can be safely removed by running pnpm audit",
	"bin": {
		"scan-overrides": "dist/index.js"
	},
	"main": "dist/lib.js",
	"types": "dist/lib.d.ts",
	"exports": {
		".": {
			"types": "./dist/lib.d.ts",
			"default": "./dist/lib.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"test": "jest",
		"test:watch": "jest --watch",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"prepublishOnly": "pnpm build && pnpm test"
	},
	"keywords": [
		"pnpm",
		"overrides",
		"security",
		"cve",
		"ghsa",
		"audit",
		"cleanup",
		"vulnerabilities",
		"npm-overrides",
		"dependency-management"
	],
	"author": "shtbik",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/shtbik/scan-overrides.git"
	},
	"bugs": {
		"url": "https://github.com/shtbik/scan-overrides/issues"
	},
	"homepage": "https://github.com/shtbik/scan-overrides#readme",
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"@types/jest": "^29.5.0",
		"@types/node": "^22.0.0",
		"jest": "^29.7.0",
		"memfs": "^4.0.0",
		"prettier": "^3.8.1",
		"ts-jest": "^29.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.0"
	}
}
